# WhatsApp Bot Configuration
# Copy this file to .env and fill in your values

# ===========================================
# BOT SETTINGS
# ===========================================

# Bot name displayed in messages
BOT_NAME=MIRA-MD

# Command prefix (e.g., !help, .help, /help)
BOT_PREFIX=!

# Owner phone number (with country code, no + or spaces)
# This user has full admin access and can use .update command
OWNER_NUMBER=1234567890

# Session name for storing auth data
SESSION_NAME=mira_session

# Enable debug logging
DEBUG_MODE=false

# ===========================================
# SERVER SETTINGS
# ===========================================

# API server port (Render/Railway will set PORT automatically)
PORT=3001

# Node environment (development/production)
NODE_ENV=development

# Dashboard URL for CORS (your Vercel frontend URL)
# Can be comma-separated for multiple origins
DASHBOARD_URL=http://localhost:3000

# Additional allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ===========================================
# API KEYS (Optional Features)
# ===========================================

# OpenAI API key for AI commands
OPENAI_API_KEY=

# Weather API key (openweathermap.org)
WEATHER_API_KEY=

# Translation API key
TRANSLATE_API_KEY=

# ===========================================
# DATABASE (Optional)
# ===========================================

# MongoDB connection string (optional, for persistent storage)
MONGODB_URI=

# ===========================================
# AUTO UPDATE SETTINGS
# ===========================================

# GitHub repository URL for auto-update feature
GITHUB_REPO=https://github.com/yourusername/mira-md-bot

# Enable auto-update feature
ENABLE_AUTO_UPDATE=true
